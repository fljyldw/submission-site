page {
  background: #f0f2f5;
  font-size: 28rpx;
  color: #333333;
}

.container {
  padding: 24rpx 24rpx 32rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 22rpx;
  color: #1a1a2e;
}

.label {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.input {
  width: 100%;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 18rpx 16rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  background: #fafafa;
}

.btn {
  margin-top: 12rpx;
}

.muted {
  color: #888;
  font-size: 24rpx;
}

.page-head {
  margin-bottom: 20rpx;
}

.page-head-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.page-head-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8c8c99;
}

.primary-btn {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 12rpx;
  border: none;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.ghost-btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  border: 2rpx solid #dcdff0;
  color: #4d5676;
  background: #fff;
  font-size: 28rpx;
}

.status-pill {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  margin-left: 10rpx;
}

.status-pass {
  background: #e6f7ed;
  color: #1e8c4d;
}

.status-fail {
  background: #fef0f0;
  color: #d63031;
}
